# =========================
# DJANGO CORE SETTINGS
# =========================
DEBUG=False
SECRET_KEY=django-insecure-change-this-to-a-very-long-random-string

# Comma-separated list
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,13.61.173.250

# =========================
# DATABASE (POSTGRESQL)
# =========================
DB_NAME=health_feedback
DB_USER=postgres
DB_PASSWORD=p@ssw0rd
DB_HOST=localhost
DB_PORT=5432

# =========================
# SECURITY (PRODUCTION)
# =========================
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# If using HTTPS with domain
CSRF_TRUSTED_ORIGINS=https://13.61.173.250

# =========================
# STATIC & MEDIA
# =========================
STATIC_URL=/static/
STATIC_ROOT=/home/ubuntu/health_feedback_app/backend/static

MEDIA_URL=/media/
MEDIA_ROOT=/home/ubuntu//health_feedback_app/backend/media

# =========================
# EMAIL (OPTIONAL)
# =========================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-password

# =========================
# TIMEZONE
# =========================
TIME_ZONE=Africa/Lusaka

# =========================
# LOGGING (OPTIONAL)
# =========================
LOG_LEVEL=INFO
